# Environment Variables Template
NODE_ENV=production

# CORS Configuration - Separados por comas
CORS_ORIGINS=https://asignacion-maternal.web.app,https://functions--asignacion-maternal.us-east4.hosted.app

# Email Configuration (opcional - configurar en Firebase Console)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587

# Security Settings
JWT_EXPIRES_IN=24h
MAX_REQUEST_SIZE=10mb

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
