{
    "firestore": {
        "rules": "firestore.rules",
        "indexes": "firestore.indexes.json"
    },
    "hosting": {
        "public": ".",
        "ignore": [
            "firebase.json",
            "**/.*",
            "**/node_modules/**",
            "functions/**"
        ],
        "rewrites": [
            {
                "source": "/assets/**",
                "destination": "/assets/**"
            },
            {
                "source": "**",
                "function": "api"
            }
        ]
    },
    "functions": {
        "source": "functions",
        "runtime": "nodejs20"
    }
}
