                              "fontFamily": "Inter",
                              "fontSize": 12,
                              "fontWeight": "600",
                              "width": 120
                            },
                            {
                              "id": "headerStatus",
                              "type": "text",
                              "content": "Estado",
                              "fill": "#4a5568",
                              "fontFamily": "Inter",
                              "fontSize": 12,
                              "fontWeight": "600",
                              "width": 100
