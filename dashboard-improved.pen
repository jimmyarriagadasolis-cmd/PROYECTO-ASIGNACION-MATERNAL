{
  "name": "Dashboard Mejorado - Sistema de Asignaciones",
  "type": "document",
  "children": [
    {
      "id": "page",
      "type": "frame",
      "name": "Dashboard Page",
      "layout": "vertical",
      "width": 1440,
      "height": "fit_content(900)",
      "fill": "#ffffff",
      "children": [
        {
          "id": "header",
          "type": "frame",
          "name": "Header",
          "layout": "horizontal",
          "width": "fill_container",
          "height": 64,
          "padding": [0, 24],
          "alignItems": "center",
          "justifyContent": "space_between",
          "fill": "#f8fafc",
          "stroke": {
            "align": "inside",
            "fill": "#e2e8f0",
            "thickness": {
              "bottom": 1
            }
          },
          "children": [
            {
              "id": "headerLeft",
              "type": "frame",
              "name": "Header Left",
              "layout": "horizontal",
              "width": "fit_content",
              "height": "fill_container",
              "alignItems": "center",
              "gap": 16,
              "children": [
                {
                  "id": "logo",
                  "type": "frame",
                  "name": "Logo",
                  "width": 40,
                  "height": 40,
                  "fill": "#3182ce",
                  "cornerRadius": 8
                },
                {
                  "id": "title",
                  "type": "text",
                  "content": "Sistema de Asignaciones 1.0",
                  "fill": "#1a202c",
                  "fontFamily": "Inter",
                  "fontSize": 20,
                  "fontWeight": "600"
                }
              ]
            },
            {
              "id": "headerRight",
              "type": "frame",
              "name": "Header Right",
              "layout": "horizontal",
              "width": "fit_content",
              "height": "fill_container",
              "alignItems": "center",
              "gap": 16,
              "children": [
                {
                  "id": "notificationBtn",
                  "type": "icon_font",
                  "iconFontFamily": "lucide",
                  "iconFontName": "bell",
                  "width": 24,
                  "height": 24,
                  "fill": "#4a5568"
                },
                {
                  "id": "userAvatar",
                  "type": "frame",
                  "name": "User Avatar",
                  "width": 32,
                  "height": 32,
                  "fill": "#3182ce",
                  "cornerRadius": 16
                }
              ]
            }
          ]
        },
        {
          "id": "mainContent",
          "type": "frame",
          "name": "Main Content",
          "layout": "vertical",
          "width": "fill_container",
          "height": "fit_content(836)",
          "padding": 32,
          "gap": 24,
          "children": [
            {
              "id": "metricsRow",
              "type": "frame",
              "name": "Metrics Row",
              "layout": "horizontal",
              "width": "fill_container",
              "height": "fit_content",
              "gap": 16,
              "children": [
                {
                  "id": "metricCard1",
                  "type": "frame",
                  "name": "Total Solicitudes",
                  "layout": "vertical",
                  "width": "fill_container",
                  "height": "fit_content",
                  "padding": 24,
                  "fill": "#ffffff",
                  "cornerRadius": 8,
                  "stroke": {
                    "align": "inside",
                    "fill": "#e2e8f0",
                    "thickness": 1
                  },
                  "children": [
                    {
                      "id": "metricLabel1",
                      "type": "text",
                      "content": "Total Solicitudes",
                      "fill": "#718096",
                      "fontFamily": "Inter",
                      "fontSize": 14,
                      "fontWeight": "500"
                    },
                    {
                      "id": "metricValue1",
                      "type": "text",
                      "content": "247",
                      "fill": "#1a202c",
                      "fontFamily": "Inter",
                      "fontSize": 32,
                      "fontWeight": "700",
                      "margin": {
                        "top": 8
                      }
                    },
                    {
                      "id": "metricChange1",
                      "type": "text",
                      "content": "+12% vs mes anterior",
                      "fill": "#48bb78",
                      "fontFamily": "Inter",
                      "fontSize": 12,
                      "fontWeight": "500",
                      "margin": {
                        "top": 4
                      }
                    }
                  ]
                },
                {
                  "id": "metricCard2",
                  "type": "frame",
                  "name": "Monto Total",
                  "layout": "vertical",
                  "width": "fill_container",
                  "height": "fit_content",
                  "padding": 24,
                  "fill": "#ffffff",
                  "cornerRadius": 8,
                  "stroke": {
                    "align": "inside",
                    "fill": "#e2e8f0",
                    "thickness": 1
                  },
                  "children": [
                    {
                      "id": "metricLabel2",
                      "type": "text",
                      "content": "Monto Total Asignado",
                      "fill": "#718096",
                      "fontFamily": "Inter",
                      "fontSize": 14,
                      "fontWeight": "500"
                    },
                    {
                      "id": "metricValue2",
                      "type": "text",
                      "content": "$45.2M",
                      "fill": "#1a202c",
                      "fontFamily": "Inter",
                      "fontSize": 32,
                      "fontWeight": "700",
                      "margin": {
                        "top": 8
                      }
                    },
                    {
                      "id": "metricChange2",
                      "type": "text",
                      "content": "+8% vs mes anterior",
                      "fill": "#48bb78",
                      "fontFamily": "Inter",
                      "fontSize": 12,
                      "fontWeight": "500",
                      "margin": {
                        "top": 4
                      }
                    }
                  ]
                },
                {
                  "id": "metricCard3",
                  "type": "frame",
                  "name": "Aprobadas",
                  "layout": "vertical",
                  "width": "fill_container",
                  "height": "fit_content",
                  "padding": 24,
                  "fill": "#ffffff",
                  "cornerRadius": 8,
                  "stroke": {
                    "align": "inside",
                    "fill": "#e2e8f0",
                    "thickness": 1
                  },
                  "children": [
                    {
                      "id": "metricLabel3",
                      "type": "text",
                      "content": "Solicitudes Aprobadas",
                      "fill": "#718096",
                      "fontFamily": "Inter",
                      "fontSize": 14,
                      "fontWeight": "500"
                    },
                    {
                      "id": "metricValue3",
                      "type": "text",
                      "content": "189",
                      "fill": "#1a202c",
                      "fontFamily": "Inter",
                      "fontSize": 32,
                      "fontWeight": "700",
                      "margin": {
                        "top": 8
                      }
                    },
                    {
                      "id": "metricChange3",
                      "type": "text",
                      "content": "76.5% tasa de aprobación",
                      "fill": "#4a5568",
                      "fontFamily": "Inter",
                      "fontSize": 12,
                      "fontWeight": "500",
                      "margin": {
                        "top": 4
                      }
                    }
                  ]
                },
                {
                  "id": "metricCard4",
                  "type": "frame",
                  "name": "En Proceso",
                  "layout": "vertical",
                  "width": "fill_container",
                  "height": "fit_content",
                  "padding": 24,
                  "fill": "#ffffff",
                  "cornerRadius": 8,
                  "stroke": {
                    "align": "inside",
                    "fill": "#e2e8f0",
                    "thickness": 1
                  },
                  "children": [
                    {
                      "id": "metricLabel4",
                      "type": "text",
                      "content": "En Revisión",
                      "fill": "#718096",
                      "fontFamily": "Inter",
                      "fontSize": 14,
                      "fontWeight": "500"
                    },
                    {
                      "id": "metricValue4",
                      "type": "text",
                      "content": "58",
                      "fill": "#1a202c",
                      "fontFamily": "Inter",
                      "fontSize": 32,
                      "fontWeight": "700",
                      "margin": {
                        "top": 8
                      }
                    },
                    {
                      "id": "metricChange4",
                      "type": "text",
                      "content": "-5% vs mes anterior",
                      "fill": "#f56565",
                      "fontFamily": "Inter",
                      "fontSize": 12,
                      "fontWeight": "500",
                      "margin": {
                        "top": 4
                      }
                    }
                  ]
                }
              ]
            },
            {
              "id": "contentRow",
              "type": "frame",
              "name": "Content Row",
              "layout": "horizontal",
              "width": "fill_container",
              "height": "fit_content(600)",
              "gap": 24,
              "children": [
                {
                  "id": "recentRequests",
