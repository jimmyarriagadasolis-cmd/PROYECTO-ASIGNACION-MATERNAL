rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function getUserRole() {
      return get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.rol;
    }
    
    function isAdmin() {
      return isAuthenticated() && getUserRole() == 'administrador';
    }
    
    function isRRHH() {
      return isAuthenticated() && getUserRole() == 'rrhh';
    }
    
    function isJefatura() {
      return isAuthenticated() && getUserRole() == 'jefatura';
    }
    
    function canWrite() {
      return isAdmin() || isRRHH() || isJefatura();
    }
    
    function canRead() {
      return isAuthenticated(); // Todos los usuarios autenticados pueden leer
    }
    
    // Reglas para solicitudes
    match /solicitudes/{solicitudId} {
      allow read: if canRead();
      allow create: if canWrite() && 
        // Validación de campos requeridos
        request.resource.data.keys().hasAll([
          'rut_funcionaria', 
          'nombre_completo', 
          'departamento_unidad',
          'fecha_ingreso_solicitud',
          'sueldo_bruto_mensual',
          'estado_solicitud'
        ]) &&
        // Validación de tipos de datos
        request.resource.data.rut_funcionaria is string &&
        request.resource.data.nombre_completo is string &&
        request.resource.data.departamento_unidad is string &&
        request.resource.data.fecha_ingreso_solicitud is string &&
        request.resource.data.sueldo_bruto_mensual is int &&
        request.resource.data.estado_solicitud is string &&
        // Validación de formato de RUT (7-8 caracteres + K)
        request.resource.data.rut_funcionaria.matches(/^[0-9Kk]{7,8}$/) &&
        // Validación de valores
        request.resource.data.sueldo_bruto_mensual > 0 &&
        request.resource.data.sueldo_bruto_mensual <= 10000000 &&
        // Validación de estado
        request.resource.data.estado_solicitud in ['Ingresada', 'En Revisión', 'Aprobada', 'Rechazada'];
      allow update: if canWrite() && 
        // Permitir actualización solo de campos específicos
        request.resource.data.diff(resource.data).affectedKeys().hasAll([
          'estado_solicitud', 
          'observaciones',
          'fecha_aprobacion'
        ]) ||
        request.resource.data.diff(resource.data).affectedKeys().size() == 0;
      allow delete: if isAdmin();
    }
    
    // Reglas para usuarios
    match /usuarios/{userId} {
      allow read: if canRead();
      allow create: if isAdmin();
      allow update: if isAdmin() || request.auth.uid == userId; // Los usuarios pueden actualizar su propio perfil
      allow delete: if isAdmin();
    }
    
    // Reglas para configuración
    match /configuracion/{configId} {
      allow read: if canRead();
      allow write: if isAdmin();
    }
    
    // Reglas para logs de auditoría
    match /logs_auditoria/{logId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated();
      allow update, delete: if false; // Los logs no se modifican ni eliminan
    }
    
    // Reglas para historial de correos
    match /historial_correos/{correoId} {
      allow read: if canRead();
      allow create: if canWrite();
      allow update: if isAdmin();
      allow delete: if false;
    }
  }
}
